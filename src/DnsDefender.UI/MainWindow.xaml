<Window x:Class="DnsDefender.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Name="RootWindow"
        mc:Ignorable="d"
        Loaded="OnMainWindowLoaded"
        Title="DNS解析溯源工具" Icon="pack://application:,,,/Assets/app-icon.ico" Height="760" Width="1320"
        MinHeight="640" MinWidth="1100">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="仅限授权环境使用（防御排查）"
                   FontWeight="Bold"
                   Margin="0,0,0,10" />

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="域名包含：" />
            <TextBox Grid.Column="1" Margin="8,0,12,0" Text="{Binding DomainKeyword, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Column="2" VerticalAlignment="Center" Text="开始时间：" />
            <DatePicker Grid.Column="3" Margin="8,0,12,0" SelectedDate="{Binding FromLocal}" />

            <TextBlock Grid.Column="4" VerticalAlignment="Center" Text="结束时间：" />
            <DatePicker Grid.Column="5" Margin="8,0,0,0" SelectedDate="{Binding ToLocal}" />

            <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="7" Margin="0,10,0,0" Orientation="Horizontal">
                <Button Content="开始记录" MinWidth="90" Margin="0,0,8,0" Command="{Binding StartCaptureCommand}" />
                <Button Content="停止记录" MinWidth="90" Margin="0,0,8,0" Command="{Binding StopCaptureCommand}" />
                <Button Content="搜索" MinWidth="80" Margin="0,0,8,0" Command="{Binding SearchCommand}" />
                <Button Content="清理历史日志" MinWidth="120" Margin="0,0,8,0" Command="{Binding ClearHistoryCommand}" />
                <Button Content="导出 CSV" MinWidth="100" Margin="0,0,8,0" Command="{Binding ExportCsvCommand}" />
                <Button Content="导出 JSON" MinWidth="100" Margin="0,0,12,0" Command="{Binding ExportJsonCommand}" />
                <CheckBox Content="启用网卡抓包DNS" VerticalAlignment="Center" IsChecked="{Binding EnablePacketCapture}" Margin="0,0,8,0" />
                <TextBlock Text="网卡：" VerticalAlignment="Center" Margin="0,0,4,0" />
                <ComboBox Width="360"
                          VerticalAlignment="Center"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="InterfaceId"
                          SelectedValue="{Binding SelectedCaptureInterfaceId}"
                          ItemsSource="{Binding AvailableCaptureInterfaces}"
                          IsEnabled="{Binding IsCaptureInterfaceSelectionEnabled}" />
            </WrapPanel>
        </Grid>

        <WrapPanel Grid.Row="2" Margin="0,0,0,10" Orientation="Horizontal">
            <TextBlock VerticalAlignment="Center" Text="列显示：" Margin="0,0,8,0" />
            <CheckBox x:Name="ChkShowQueryType" VerticalAlignment="Center" Content="类型" IsChecked="{Binding ShowQueryTypeColumn}" Checked="OnColumnToggleChanged" Unchecked="OnColumnToggleChanged" Margin="0,0,10,0" />
            <CheckBox x:Name="ChkShowResponseCode" VerticalAlignment="Center" Content="响应码" IsChecked="{Binding ShowResponseCodeColumn}" Checked="OnColumnToggleChanged" Unchecked="OnColumnToggleChanged" Margin="0,0,10,0" />
            <CheckBox x:Name="ChkShowReturnedIps" VerticalAlignment="Center" Content="返回IP" IsChecked="{Binding ShowReturnedIpsColumn}" Checked="OnColumnToggleChanged" Unchecked="OnColumnToggleChanged" Margin="0,0,10,0" />
            <CheckBox x:Name="ChkShowAttributionStatus" VerticalAlignment="Center" Content="归因状态" IsChecked="{Binding ShowAttributionStatusColumn}" Checked="OnColumnToggleChanged" Unchecked="OnColumnToggleChanged" Margin="0,0,10,0" />
            <CheckBox x:Name="ChkShowAttributionConfidence" VerticalAlignment="Center" Content="置信度" IsChecked="{Binding ShowAttributionConfidenceColumn}" Checked="OnColumnToggleChanged" Unchecked="OnColumnToggleChanged" />
        </WrapPanel>

        <TextBlock Grid.Row="3"
                   Margin="0,0,0,10"
                   FontStyle="Italic"
                   Text="{Binding CapabilityText}" />

        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding Records}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间(本地)" Width="180" Binding="{Binding TimestampLocal, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" />
                <DataGridTextColumn Header="域名" Width="220" Binding="{Binding Domain}" />
                <DataGridTextColumn x:Name="ColQueryType" Header="类型" Width="60" Binding="{Binding QueryType}" />
                <DataGridTextColumn x:Name="ColResponseCode" Header="响应码" Width="80" Binding="{Binding ResponseCode}" />
                <DataGridTextColumn x:Name="ColReturnedIps" Header="返回IP" Width="200" Binding="{Binding ReturnedIps}" />
                <DataGridTextColumn Header="进程ID" Width="70" Binding="{Binding ProcessId}" />
                <DataGridTextColumn Header="进程名" Width="140" Binding="{Binding ProcessName}" />
                <DataGridTextColumn Header="可执行路径" Width="280" Binding="{Binding ExecutablePath}" />
                <DataGridTextColumn x:Name="ColAttributionStatus" Header="归因状态" Width="95" Binding="{Binding AttributionStatusText}" />
                <DataGridTextColumn x:Name="ColAttributionConfidence" Header="置信度" Width="85" Binding="{Binding AttributionConfidence}" />
                <DataGridTextColumn Header="来源" Width="100" Binding="{Binding Source}" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="5"
                   Margin="0,10,0,0"
                   Text="{Binding StatusText}" />
    </Grid>
</Window>
